# .env.example → 실제 사용 시 .env.local 로 복사

# Aurora Serverless v2 (RDS Proxy 엔드포인트 사용 권장)
DATABASE_URL="postgresql://user:password@your-rds-proxy.rds.amazonaws.com:5432/notesite?connection_limit=1"

# JWT 비밀키 (32자 이상 랜덤 문자열)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# 앱 도메인
NEXT_PUBLIC_APP_URL="https://notil.click"
